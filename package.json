{
  "name": "rockaden-wp",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter plugin dev",
    "typecheck": "pnpm --filter plugin typecheck",
    "lint": "pnpm --filter plugin lint:js",
    "check": "pnpm typecheck && pnpm lint && pnpm build",
    "package": "pnpm build && node scripts/package.mjs"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "core-js",
      "core-js-pure",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
