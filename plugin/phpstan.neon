parameters:
    level: 6
    bootstrapFiles:
        - phpstan-bootstrap.php
    paths:
        - rockaden-chess.php
        - src/
    scanDirectories:
        - vendor/php-stubs/wordpress-stubs/
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # wp-scripts generates .asset.php files during JS build; not available in PHP-only CI
        -
            identifier: require.fileNotFound
            paths:
                - src/Admin/TrainingAdmin.php
                - src/Admin/EventMetaBoxes.php
