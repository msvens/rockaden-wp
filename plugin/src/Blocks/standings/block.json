{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rockaden/standings",
  "version": "0.2.0",
  "title": "Tournament Standings",
  "category": "widgets",
  "icon": "editor-ol",
  "description": "Displays standings for a tournament.",
  "textdomain": "rockaden-chess",
  "attributes": {
    "tournamentId": {
      "type": "number",
      "default": 0
    },
    "showRounds": {
      "type": "boolean",
      "default": true
    }
  },
  "supports": {
    "html": false,
    "align": ["wide"]
  },
  "editorScript": "file:../../../build/blocks/standings/index.js",
  "viewScript": "file:../../../build/blocks/standings/view.js",
  "viewStyle": "file:../../../build/blocks/standings/view.css",
  "render": "file:./render.php"
}
