{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rockaden/shop-grid",
  "version": "0.1.0",
  "title": "Shop Items",
  "category": "widgets",
  "icon": "cart",
  "description": "Displays shop items (chess equipment for sale).",
  "textdomain": "rockaden-theme",
  "attributes": {
    "count": {
      "type": "number",
      "default": 0
    },
    "moreUrl": {
      "type": "string",
      "default": "/shop"
    },
    "moreLabel": {
      "type": "string"
    },
    "layout": {
      "type": "string",
      "default": "grid",
      "enum": ["grid", "column"]
    },
    "display": {
      "type": "string",
      "default": "full",
      "enum": ["full", "condensed"]
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}
