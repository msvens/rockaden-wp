{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "rockaden/feedback-form",
  "version": "0.1.0",
  "title": "Feedback Form",
  "category": "widgets",
  "icon": "email",
  "description": "A 'send us feedback' form that emails the club and stores submissions.",
  "textdomain": "rockaden-theme",
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "intro": {
      "type": "string",
      "default": ""
    },
    "formAlign": {
      "type": "string",
      "default": "left",
      "enum": ["left", "center"]
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}
