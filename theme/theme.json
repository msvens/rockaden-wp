{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1024px",
      "wideSize": "1280px"
    },
    "color": {
      "custom": false,
      "customGradient": false,
      "palette": [
        { "slug": "primary", "color": "#2563eb", "name": "Primary" },
        { "slug": "primary-light", "color": "#60a5fa", "name": "Primary Light" },
        { "slug": "surface", "color": "#ffffff", "name": "Surface" },
        { "slug": "surface-dim", "color": "#f3f4f6", "name": "Surface Dim" },
        { "slug": "on-surface", "color": "#111827", "name": "On Surface" },
        { "slug": "on-surface-muted", "color": "#4b5563", "name": "On Surface Muted" },
        { "slug": "border", "color": "#e5e7eb", "name": "Border" },
        { "slug": "error", "color": "#dc2626", "name": "Error" },
        { "slug": "success", "color": "#16a34a", "name": "Success" },
        { "slug": "cat-training", "color": "#2563eb", "name": "Training" },
        { "slug": "cat-tournament", "color": "#dc2626", "name": "Tournament" },
        { "slug": "cat-junior", "color": "#16a34a", "name": "Junior" },
        { "slug": "cat-allsvenskan", "color": "#7c3aed", "name": "Allsvenskan" },
        { "slug": "cat-skolschack", "color": "#ea580c", "name": "Skolschack" }
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "fontFamily": "'Geist Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "slug": "geist",
          "name": "Geist Sans",
          "fontFace": [
            {
              "fontFamily": "Geist Sans",
              "fontWeight": "100 900",
              "fontStyle": "normal",
              "fontDisplay": "swap",
              "src": [ "file:./assets/fonts/geist-latin-wght-normal.woff2" ]
            }
          ]
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.25rem", "name": "Large" },
        { "slug": "x-large", "size": "1.5rem", "name": "X-Large" },
        { "slug": "xx-large", "size": "2.25rem", "name": "XX-Large" },
        { "slug": "xxx-large", "size": "3rem", "name": "XXX-Large" }
      ]
    },
    "spacing": {
      "units": [ "px", "em", "rem", "%", "vh", "vw" ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--surface)",
      "text": "var(--wp--preset--color--on-surface)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--geist)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--primary)"
          },
          "typography": {
            "textDecoration": "none"
          }
        },
        "typography": {
          "textDecoration": "none"
        }
      },
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--on-surface)"
        },
        "typography": {
          "fontWeight": "300",
          "letterSpacing": "0.025em"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xxx-large)"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xx-large)"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": "500"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "500"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--medium)",
          "fontWeight": "600"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "600"
        }
      },
      "button": {
        "color": {
          "background": "transparent",
          "text": "var(--wp--preset--color--on-surface-muted)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--surface-dim)",
            "text": "var(--wp--preset--color--on-surface)"
          }
        },
        "border": {
          "radius": "0.25rem",
          "color": "var(--wp--preset--color--border)",
          "width": "1px",
          "style": "solid"
        },
        "typography": {
          "fontSize": "0.8125rem",
          "fontWeight": "500"
        },
        "spacing": {
          "padding": {
            "top": "0.25rem",
            "bottom": "0.25rem",
            "left": "0.75rem",
            "right": "0.75rem"
          }
        }
      }
    },
    "spacing": {
      "blockGap": "1.5rem"
    }
  },
  "customTemplates": [
    { "name": "page-section", "title": "Page (Section Nav)", "postTypes": ["page"] }
  ],
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
